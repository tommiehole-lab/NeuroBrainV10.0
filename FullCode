import random
import math
from collections import defaultdict

# --- 1. THE ENVIRONMENT ---

class ComplexEnv:
    """A 2D grid-world with hazards, a goal (cube), and a delivery target."""
    def __init__(self, size=6):
        self.size = size
        self.reset()

    def reset(self):
        self.robot_pos = [0, 0]
        self.cube_pos = [self.size-1, 1]
        self.target_pos = [self.size-1, self.size-1]
        self.hazard_pos = [self.size//2, self.size//2]
        self.has_cube = False
        return self.get_observation()

    def get_observation(self):
        obs = [f"pos_{tuple(self.robot_pos)}"]
        if math.dist(self.robot_pos, self.hazard_pos) < 1.1: obs.append("near_hazard")
        if self.robot_pos == self.hazard_pos: obs.append("in_hazard")
        if self.robot_pos == self.cube_pos: obs.append("at_cube")
        if self.has_cube: obs.append("holding_cube")
        return obs

    def step(self, action):
        move = {"up": [0, 1], "down": [0, -1], "left": [-1, 0], "right": [1, 0]}
        step = move.get(action, [0, 0])
        
        # Physics: Boundary constraints
        self.robot_pos[0] = max(0, min(self.size - 1, self.robot_pos[0] + step[0]))
        self.robot_pos[1] = max(0, min(self.size - 1, self.robot_pos[1] + step[1]))

        reward = -0.02  # Metabolic cost of movement
        done = False
        info = {"hit_hazard": False}

        if self.robot_pos == self.hazard_pos:
            reward -= 5.0  # Massive trauma penalty
            info["hit_hazard"] = True
        
        if self.robot_pos == self.cube_pos and not self.has_cube:
            self.has_cube = True
            reward += 3.0
            print(">> [Object Acquired]")

        if self.robot_pos == self.target_pos and self.has_cube:
            reward += 20.0
            done = True
        
        return reward, done, info

# --- 2. BRAIN REGIONS ---

class Amygdala:
    """Handles one-trial learning and instant fear responses."""
    def __init__(self):
        self.trauma_stimuli = set()

    def learn_fear(self, events):
        for e in events:
            self.trauma_stimuli.add(e)

    def detect_danger(self, events):
        return any(e in self.trauma_stimuli for e in events)

class Hypothalamus:
    """Manages internal homeostasis (Energy & Survival)."""
    def __init__(self):
        self.energy = 1.0
        self.recharge_zone = (0, 0)

    def update(self, pos, hit_hazard):
        self.energy -= 0.02 # Drain per step
        if hit_hazard: self.energy -= 0.15
        if tuple(pos) == self.recharge_zone:
            self.energy = min(1.0, self.energy + 0.4)

    def get_drive(self):
        return "SURVIVAL" if self.energy < 0.3 else "EXPLORE"

class Thalamus:
    """Gates sensory information based on current drive."""
    def gate_sensory(self, obs, drive):
        if drive == "SURVIVAL":
            # Filter out non-essential stimuli (ignore cube, focus on home/hazard)
            return [o for o in obs if "pos" in o or "hazard" in o]
        return obs

class VTA_Dopamine:
    """Calculates Reward Prediction Error (RPE) to tune learning speed."""
    def __init__(self):
        self.tonic_level = 0.5

    def calculate_learning_gain(self, reward):
        # High surprise (phasic burst) leads to faster learning
        gain = 1.0 + abs(reward)
        self.tonic_level = 0.9 * self.tonic_level + 0.1 * (0.5 + (reward * 0.1))
        return gain

class Hippocampus:
    """Stores episodic memories and facilitates offline replay (Sleep)."""
    def __init__(self):
        self.buffer = []

    def record(self, state, action, reward, obs):
        self.buffer.append((state, action, reward, obs))

    def replay_and_consolidate(self, bg, ofc):
        # Replay the 'best' and 'worst' memories 10 times (REM Sleep)
        important = sorted(self.buffer, key=lambda x: abs(x[2]), reverse=True)[:5]
        for s, a, r, obs in important:
            bg[s][a] += r * 0.5
            for o in obs: ofc[o] += r * 0.1

class PrefrontalCortex:
    """Executive function: World modeling and Action Vetoing."""
    def __init__(self):
        self.model = {} # (pos, action) -> predicted_next_pos

    def learn_physics(self, s, a, s_next):
        self.model[(s, a)] = s_next

    def simulate(self, s, a, ofc_values):
        s_next = self.model.get((s, a))
        if s_next and ofc_values.get(f"pos_{s_next}", 0) < -2.0:
            return "VETO"
        return "ALLOW"

# --- 3. THE INTEGRATED AGENT ---

class NeuroBrainV10:
    def __init__(self, env):
        self.env = env
        self.amygdala = Amygdala()
        self.hypo = Hypothalamus()
        self.thalamus = Thalamus()
        self.vta = VTA_Dopamine()
        self.hippo = Hippocampus()
        self.pfc = PrefrontalCortex()
        
        self.ofc = defaultdict(float) # Value Map
        self.bg = defaultdict(lambda: defaultdict(float)) # Habit Map
        
        self.current_goal = "find_cube"
        self.last_state = None
        self.last_action = None

    def reset_episode(self):
        """Triggers the 'sleep' cycle between episodes."""
        self.hippo.replay_and_consolidate(self.bg, self.ofc)
        self.hippo.buffer = []
        self.hypo.energy = 1.0
        self.current_goal = "find_cube"

    def decide(self):
        raw_obs = self.env.get_observation()
        drive = self.hypo.get_drive()
        gated_obs = self.thalamus.gate_sensory(raw_obs, drive)
        curr_pos = tuple(self.env.robot_pos)

        # 1. Amygdala Emergency Override
        if self.amygdala.detect_danger(gated_obs):
            return random.choice(["up", "down", "left", "right"])

        # 2. Hypothalamus Survival Drive (Heuristic Home-seeking)
        if drive == "SURVIVAL":
            if curr_pos[0] > 0: return "left"
            if curr_pos[1] > 0: return "down"

        # 3. Basal Ganglia Habit Selection
        state_key = (self.current_goal, curr_pos)
        if state_key in self.bg:
            action = max(self.bg[state_key], key=self.bg[state_key].get)
        else:
            action = random.choice(["up", "down", "left", "right"])

        # 4. PFC Executive Veto
        if self.pfc.simulate(curr_pos, action, self.ofc) == "VETO":
            return random.choice(["up", "down", "left", "right"])

        return action

    def perceive_and_learn(self, reward, action, info):
        obs = self.env.get_observation()
        curr_pos = tuple(self.env.robot_pos)
        
        # Amygdala Fear Learning
        if info["hit_hazard"]:
            self.amygdala.learn_fear(obs)
            self.ofc[f"pos_{curr_pos}"] -= 10.0
        
        # VTA Gain Calculation
        gain = self.vta.calculate_learning_gain(reward)
        
        # BG Habit Learning
        state_key = (self.current_goal, curr_pos)
        self.bg[state_key][action] += reward * gain
        
        # PFC Physics Learning
        if self.last_state:
            self.pfc.learn_physics(self.last_state, action, curr_pos)
        
        # Hippocampal Memory Encoding
        self.hippo.record(state_key, action, reward, obs)
        self.hypo.update(curr_pos, info["hit_hazard"])
        
        # Goal Progression
        if self.env.has_cube: self.current_goal = "deliver_cube"
        self.last_state = curr_pos

# --- 4. MAIN EXECUTION LOOP ---

if __name__ == "__main__":
    env = ComplexEnv()
    brain = NeuroBrainV10(env)
    
    for ep in range(1, 11):
        env.reset()
        brain.reset_episode()
        print(f"\n--- Episode {ep} | Energy: {brain.hypo.energy:.2f} ---")
        
        for step in range(60):
            action = brain.decide()
            reward, done, info = env.step(action)
            brain.perceive_and_learn(reward, action, info)
            
            if done:
                print(f"🎉 Success at step {step}! Target Reached.")
                break
        else:
            print("❌ Timeout.")
